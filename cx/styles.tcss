/* cx TUI — Claude-branded dark theme */

Screen {
    layout: vertical;
    background: ansi_default;
}

#title-bar {
    height: 3;
    padding: 0 1;
    border: round #555555;
}

WorktreePanel {
    width: 100%;
    height: auto;
    min-height: 5;
    border: round #555555;
    border-title-color: #555555;
    border-title-style: bold;
    padding: 0 1;
}

WorktreePanel:focus-within {
    border: round #DA7756;
    border-title-color: #DA7756;
}

#session-columns {
    height: auto;
    width: 100%;
}

#claude-column {
    width: 1fr;
    height: auto;
}

#codex-column {
    width: 1fr;
    height: auto;
}

SessionPanel {
    width: 100%;
    height: 1fr;
    border: round #555555;
    border-title-color: #555555;
    border-title-style: bold;
    padding: 0 1;
}

SessionPanel:focus-within {
    border: round #DA7756;
    border-title-color: #DA7756;
}

CodexSessionPanel {
    width: 100%;
    height: 1fr;
    border: round #555555;
    border-title-color: #555555;
    border-title-style: bold;
    padding: 0 1;
}

CodexSessionPanel:focus-within {
    border: round #DA7756;
    border-title-color: #DA7756;
}

Footer {
    background: ansi_default;
    dock: none;
}

FooterKey {
    background: ansi_default;
}

.footer-key--key {
    background: ansi_default;
    color: #DA7756;
    text-style: bold;
}

.footer-key--description {
    background: ansi_default;
    color: ansi_default;
}

StatusBar {
    height: 3;
    width: 100%;
    border: round #555555;
    border-title-color: #555555;
    border-title-style: bold;
    padding: 0 1;
}

SettingsPanel {
    height: auto;
    width: 100%;
    border: round #555555;
    border-title-color: #555555;
    border-title-style: bold;
    padding: 0 1;
}

SettingsPanel:focus-within {
    border: round #DA7756;
    border-title-color: #DA7756;
}

SettingsPanel ListView {
    height: auto;
}

CodexSettingsPanel {
    height: auto;
    width: 100%;
    border: round #555555;
    border-title-color: #555555;
    border-title-style: bold;
    padding: 0 1;
}

CodexSettingsPanel:focus-within {
    border: round #DA7756;
    border-title-color: #DA7756;
}

CodexSettingsPanel ListView {
    height: auto;
}

.setting-name {
    width: 1fr;
}

.setting-value {
    width: auto;
    content-align: right middle;
}

/* List items */
WorktreePanel ListView {
    height: auto;
}

SessionPanel ListView {
    height: auto;
}

CodexSessionPanel ListView {
    height: auto;
}

ListView > ListItem.-highlight {
    background: transparent;
    text-style: none;
}

ListView:focus > ListItem.-highlight {
    background: rgba(255, 255, 255, 0.3);
    text-style: none;
}

#worktree-list > ListItem.-highlight {
    background: rgba(255, 255, 255, 0.2);
    text-style: none;
}

#worktree-list:focus > ListItem.-highlight {
    background: rgba(255, 255, 255, 0.3);
    text-style: none;
}

ListItem {
    height: 1;
    padding: 0 1;
}

ListItem Horizontal {
    height: 1;
    width: 100%;
}

.session-name {
    width: 1fr;
}

.session-indicator {
    width: 1;
    content-align: right middle;
}

/* Inline confirm */
.confirm-label {
    width: 1fr;
}

.confirm-choices {
    width: auto;
    content-align: right middle;
}

/* Inline inputs */
.inline-create {
    height: 1;
    width: 100%;
}

.inline-create Input {
    height: 1;
    border: none;
    width: 1fr;
    padding: 0 1;
}

.inline-input {
    height: 1;
    border: none;
    padding: 0 1;
}

#session-rename {
    width: 1fr;
    padding: 0;
    background: transparent;
}

#codex-session-rename {
    width: 1fr;
    padding: 0;
    background: transparent;
}

/* Empty state — padding is horizontal-only so a 1-row panel can fit it;
   content_height reports 1 for panels in the empty state, so any vertical
   padding here clips the message entirely. `dim` matches the version text
   in the title bar (which uses rich `[dim]` markup). */
.empty-message {
    text-style: dim;
    padding: 0 1;
}

/* Modal dialogs (confirm) */
ModalScreen {
    align: center middle;
}

.modal-container {
    width: 60;
    height: auto;
    border: round #DA7756;
    background: $surface;
    padding: 0 1;
}

.modal-container Static.modal-title {
    text-style: bold;
    color: #DA7756;
    width: 100%;
    content-align: center middle;
}

.modal-buttons {
    height: 3;
    align: center middle;
}

.modal-buttons Button {
    margin: 0 1;
    border: round #DA7756;
    min-width: 14;
}

ToastRack {
    dock: none;
    align: right top;
    margin-top: 1;
}

Toast {
    width: auto;
    height: 1;
    padding: 0 1;
    margin: 0;
}
